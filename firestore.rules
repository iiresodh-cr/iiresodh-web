rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // FUNCIÓN CORREGIDA: Utiliza path() y concatenación (+) para que Firebase 
    // pueda compilar el método .lower() sin romper el despliegue.
    function esAdmin() {
      return request.auth != null && 
             request.auth.token.email != null &&
             exists(path('/databases/' + database + '/documents/admins/' + request.auth.token.email.lower()));
    }

    // ACCESO DE LECTURA COMPILADO: Permite que el login consulte la colección de admins
    match /admins/{adminEmail} {
      allow read: if request.auth != null;
      allow write: if false; // Blindado contra registros malintencionados
    }

    match /auditoria_actividad/{document=**} {
      allow read, write: if esAdmin();
    }
    
    match /equipo/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }
    
    match /noticias/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /articulos_academicos/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /libros/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }
    
    match /informes/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /cursos/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /incidencia/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /compras/{docId=**} {
      allow read, write: if esAdmin();
    }
    
    match /configuracion/{docId=**} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // ===== FEEDBACK QA TEMPORAL =====
    match /feedback_qa/{docId=**} {
      allow read, write: if true;
    }
    // ================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}